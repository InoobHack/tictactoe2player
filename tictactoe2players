#include <iostream>
using namespace std;
char board[3][3] = {
	{'1','2','3'},
	{'4','5','6'},
	{'7','8','9'}
};
void board2() {
	cout << board[0][0] << " | " << board[0][1] << " | " << board[0][2] << endl; 
	cout << "---------" << endl;
	cout << board[1][0] << " | " << board[1][1] << " | " << board[1][2] << endl;
	cout << "---------" << endl;
	cout << board[2][0] << " | " << board[2][1] << " | " << board[2][2] << endl;
}
void player() {
	int num;
	cout << "Pick a number(1-9): ";
	cin >> num;
	if(cin.fail()) {
		cin.clear();
		cin.ignore(1000, '\n');
		cout << "Only number allowed \n";
		player();
		return;
	}



	if (num < 1 || num > 9) {
		cout << "Invalid number try again:\n";
		player();
		return;
	}

	int row = (num - 1) / 3;
	int col = (num - 1) % 3;

	if (board[row][col] != 'X' && board[row][col] != 'O') {
		board[row][col] = 'X';
	} else {
		cout << "Spot taken Try again\n";
		player();

	}
};
void player2() {
	int num2;
	cout << "Pick a number(1-9): ";
	cin >> num2;
	if(cin.fail()) {
		cin.clear();
		cin.ignore(1000, '\n');
		cout << "Only number allowed \n";
		player2();
		return;
	}



	if (num2 < 1 || num2 > 9) {
		cout << "Invalid number try again:\n";
		player2();
		return;
	}

	int row2 = (num2 - 1) / 3;
	int col2 = (num2 - 1) % 3;

	if (board[row2][col2] != 'O' && board[row2][col2] != 'X') {
		board[row2][col2] = 'O';
	} else {
		cout << "Spot taken Try again\n";
		player2();

	}
}
bool checkWin(char s) {

	if (board[0][0] == s && board[0][1] == s && board[0][2] == s) return true;
	if (board[1][0] == s && board[1][1] == s && board[1][2] == s) return true;
	if (board[2][0] == s && board[2][1] == s && board[2][2] == s) return true;

	if (board[0][0] == s && board[1][0] == s && board[2][0] == s) return true;
	if (board[0][1] == s && board[1][1] == s && board[2][1] == s) return true;
	if (board[0][2] == s && board[1][2] == s && board[2][2] == s) return true;

	if (board[0][0] == s && board[1][1] == s && board[2][2] == s) return true;
	if (board[0][2] == s && board[1][1] == s && board[2][0] == s) return true;

	return false;
}

bool isDraw() {

	for (int i = 0; i < 3; i++) {
		for (int j = 0; j < 3; j++) {

			if (board[i][j] != 'X' && board[i][j] != 'O') {
				return false;
			}
		}
	}

	return true;
}

int main() {

	while (true) {

		// Player 1 turn
		board2();
		cout << "\nPlayer 1 (X)\n";
		player();

		if (checkWin('X')) {
			board2();
			cout << "Player 1 Won!(Hit run to play again)\n";
			break;
		}

		if (isDraw()) {
			board2();
			cout << "It's a draw!\n";
			break;
		}

		// Player 2 turn
		board2();
		cout << "\nPlayer 2 (O)\n";
		player2();

		if (checkWin('O')) {
			board2();
			cout << "Player 2 Won!(Hit run to play again)\n";
			break;
		}

		if (isDraw()) {
			board2();
			cout << "It's a draw!(Hit run to play again)\n";
			break;
		}
	}

	return 0;
}
